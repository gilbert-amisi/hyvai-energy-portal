{
  "kind": "collectionType",
  "collectionName": "subscriptions",
  "info": {
    "singularName": "subscription",
    "pluralName": "subscriptions",
    "displayName": "Subscription"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Candidate": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::trainee-profile.trainee-profile"
    },
    "Track": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::training-track.training-track"
    },
    "Date": {
      "type": "date",
      "required": true
    },
    "Subscription_Status": {
      "type": "enumeration",
      "required": true,
      "default": "Pending",
      "enum": [
        "Pending",
        "Approved",
        "Rejected"
      ]
    }
  }
}
